<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link href="TicketPrime.Web.Client.styles.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <title>TicketPrime - Sua plataforma de ingressos online</title>
    <!-- MudBlazor – fontes e estilos -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
</head>

<body>
    <div id="app">
        Carregando aplicacao...
    </div>
    <!-- Crypto E2E (Web Crypto API wrapper) -->
    <script src="js/crypto.js"></script>
    <!-- Sessão persistente — refresh token no localStorage para reautenticação após F5 -->
    <script src="js/session.js"></script>
    <!-- Tema (Dark Mode) -->
    <script src="js/theme.js"></script>
    <!-- Mercado Pago — tokenização segura de cartão (iframes) -->
    <script src="js/mercadopago.js"></script>
    <!-- QR Code Scanner — leitura de ingressos via câmera (jsQR) -->
    <script src="js/qr-scanner.js"></script>
    <!-- MudBlazor JS -->
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="_framework/blazor.webassembly.js"></script>
