@page "/"
@layout EmptyLayout
@using System.Net.Http.Json
@using TicketPrime.Web.Services
@using TicketPrime.Web.Components.Layout
@rendermode InteractiveServer
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Navigation

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body { overflow-x: hidden; }

    .hp-navbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 3rem;
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(91,91,214,0.08);
        transition: box-shadow 0.3s;
    }

    .hp-nav-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
    }

    .hp-nav-logo-icon {
        width: 38px;
        height: 38px;
        background: #5B5BD6;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hp-nav-logo-icon svg { width: 20px; height: 20px; fill: white; }

    .hp-nav-logo-name {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1a1a2e;
        letter-spacing: -0.3px;
    }

    .hp-nav-links {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .hp-nav-link {
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        border: none;
        background: transparent;
        color: #374151;
        transition: background 0.2s;
    }

    .hp-nav-link:hover { background: #F3F4F6; }

    .hp-nav-btn {
        padding: 0.5rem 1.4rem;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: #5B5BD6;
        color: white;
        transition: background 0.2s, transform 0.15s;
    }

    .hp-nav-btn:hover { background: #4949c4; transform: translateY(-1px); }

    .hp-nav-user {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        background: #F0F0FF;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        color: #5B5BD6;
        cursor: pointer;
        border: none;
    }

    
    .hp-hero {
        min-height: 100vh;
        background: linear-gradient(135deg, #dde1f5 0%, #f5d6e8 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 7rem 2rem 4rem;
        position: relative;
        overflow: hidden;
    }

    .hp-hero-blob1 {
        position: absolute;
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(91,91,214,0.18) 0%, transparent 70%);
        top: -100px; left: -100px;
        animation: float1 8s ease-in-out infinite;
        pointer-events: none;
    }

    .hp-hero-blob2 {
        position: absolute;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(236,72,153,0.15) 0%, transparent 70%);
        bottom: -80px; right: -80px;
        animation: float2 10s ease-in-out infinite;
        pointer-events: none;
    }

    @@keyframes float1 {
        0%, 100% { transform: translate(0,0) scale(1); }
        50% { transform: translate(30px, 20px) scale(1.08); }
    }

    @@keyframes float2 {
        0%, 100% { transform: translate(0,0) scale(1); }
        50% { transform: translate(-20px, -30px) scale(1.05); }
    }

    .hp-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(91,91,214,0.12);
        color: #5B5BD6;
        border-radius: 20px;
        padding: 0.35rem 1rem;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        animation: fadeUp 0.6s ease both;
    }

    .hp-badge-dot {
        width: 6px; height: 6px;
        background: #5B5BD6;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.4); }
    }

    .hp-hero-title {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 800;
        color: #1a1a2e;
        line-height: 1.1;
        letter-spacing: -1px;
        margin-bottom: 1.2rem;
        animation: fadeUp 0.7s 0.1s ease both;
    }

    .hp-hero-title span {
        color: #5B5BD6;
    }

    .hp-hero-desc {
        font-size: 1.1rem;
        color: #6B7280;
        max-width: 520px;
        line-height: 1.7;
        margin-bottom: 2.5rem;
        animation: fadeUp 0.7s 0.2s ease both;
    }

    .hp-hero-btns {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
        animation: fadeUp 0.7s 0.3s ease both;
    }

    .hp-hero-btn-main {
        padding: 0.9rem 2rem;
        background: #5B5BD6;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .hp-hero-btn-main:hover { background: #4949c4; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(91,91,214,0.3); }

    .hp-hero-btn-sec {
        padding: 0.9rem 2rem;
        background: white;
        color: #5B5BD6;
        border: 2px solid #5B5BD6;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .hp-hero-btn-sec:hover { background: #F0F0FF; transform: translateY(-2px); }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to { opacity: 1; transform: translateY(0); }
    }

    
    .hp-stats {
        display: flex;
        gap: 2rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 3.5rem;
        animation: fadeUp 0.7s 0.4s ease both;
    }

    .hp-stat {
        text-align: center;
    }

    .hp-stat-num {
        font-size: 2rem;
        font-weight: 800;
        color: #5B5BD6;
    }

    .hp-stat-label {
        font-size: 0.8rem;
        color: #9CA3AF;
        margin-top: 0.2rem;
    }

    .hp-stat-divider {
        width: 1px;
        background: rgba(91,91,214,0.2);
        align-self: stretch;
    }


    .hp-features {
        padding: 5rem 2rem;
        background: #ffffff;
        text-align: center;
    }

    .hp-section-tag {
        display: inline-block;
        background: #F0F0FF;
        color: #5B5BD6;
        font-size: 0.78rem;
        font-weight: 600;
        border-radius: 20px;
        padding: 0.3rem 1rem;
        margin-bottom: 1rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .hp-section-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.6rem;
    }

    .hp-section-desc {
        color: #6B7280;
        font-size: 0.95rem;
        margin-bottom: 3rem;
    }

    .hp-feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        max-width: 960px;
        margin: 0 auto;
    }

    .hp-feature-card {
        background: #F8FAFC;
        border-radius: 18px;
        padding: 2rem 1.5rem;
        text-align: left;
        border: 1.5px solid #F1F5F9;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .hp-feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(91,91,214,0.10);
    }

    .hp-feature-icon {
        width: 48px; height: 48px;
        background: #5B5BD6;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.2rem;
    }

    .hp-feature-icon svg { width: 24px; height: 24px; stroke: white; }

    .hp-feature-title {
        font-size: 1rem;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .hp-feature-desc {
        font-size: 0.875rem;
        color: #6B7280;
        line-height: 1.6;
    }

    /* CTA */
    .hp-cta {
        background: linear-gradient(135deg, #5B5BD6 0%, #7C7CE8 100%);
        padding: 5rem 2rem;
        text-align: center;
        color: white;
    }

    .hp-cta h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.8rem;
    }

    .hp-cta p {
        font-size: 1rem;
        opacity: 0.85;
        margin-bottom: 2rem;
    }

    .hp-cta-btn {
        padding: 0.9rem 2.5rem;
        background: white;
        color: #5B5BD6;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
    }

    .hp-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }

    /* FOOTER */
    .hp-footer {
        background: #1a1a2e;
        color: #9CA3AF;
        text-align: center;
        padding: 1.5rem;
        font-size: 0.875rem;
    }

    .hp-footer span { color: #5B5BD6; }

    @@media (max-width: 768px) {
        .hp-navbar { padding: 1rem 1.5rem; }
        .hp-feature-grid { grid-template-columns: 1fr; }
        .hp-stats { gap: 1rem; }
        .hp-stat-divider { display: none; }
    }
</style>


<nav class="hp-navbar">
    <a class="hp-nav-logo" href="/">
        <div class="hp-nav-logo-icon">
            <svg viewBox="0 0 24 24"><path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4zM12 17.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0-7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>
        </div>
        <span class="hp-nav-logo-name">TicketPrime</span>
    </a>

    <div class="hp-nav-links">
        @if (Session.EstaLogado)
        {
            <button class="hp-nav-user" @onclick='() => Navigation.NavigateTo("/eventos")'>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Eventos
            </button>
            <button class="hp-nav-user" @onclick='() => Navigation.NavigateTo("/perfil")'>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
                @Session.Nome
            </button>
        }
    </div>
</nav>


<section class="hp-hero">
    <div class="hp-hero-blob1"></div>
    <div class="hp-hero-blob2"></div>

    <div class="hp-badge">
        <div class="hp-badge-dot"></div>
        Plataforma de ingressos online
    </div>

    <h1 class="hp-hero-title">
        Seus eventos favoritos,<br/>
        <span>na palma da mão</span>
    </h1>

    <p class="hp-hero-desc">
        Compre ingressos com segurança, gerencie suas reservas e aproveite os melhores eventos com a TicketPrime.
    </p>

    <div class="hp-hero-btns">
        @if (Session.EstaLogado)
        {
            <button class="hp-hero-btn-main" @onclick='() => Navigation.NavigateTo("/eventos")'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Ver Eventos
            </button>
            <button class="hp-hero-btn-sec" @onclick='() => Navigation.NavigateTo("/perfil")'>
                @(Session.EhAdmin ? "Meus Eventos" : "Meus Ingressos")
            </button>
        }
        else
        {
            <button class="hp-hero-btn-main" @onclick='() => Navigation.NavigateTo("/cadastro-user")'>
                Começar agora — é grátis
            </button>
            <button class="hp-hero-btn-sec" @onclick='() => Navigation.NavigateTo("/login")'>
                Já tenho conta
            </button>
        }
    </div>

    <div class="hp-stats">
        <div class="hp-stat">
            <div class="hp-stat-num">@totalEventos+</div>
            <div class="hp-stat-label">Eventos ativos</div>
        </div>
        <div class="hp-stat-divider"></div>
        <div class="hp-stat">
            <div class="hp-stat-num">100%</div>
            <div class="hp-stat-label">Seguro</div>
        </div>
        <div class="hp-stat-divider"></div>
        <div class="hp-stat">
            <div class="hp-stat-num">@totalReservas+</div>
            <div class="hp-stat-label">Ingressos vendidos</div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="hp-features">
    <div class="hp-section-tag">Por que escolher a TicketPrime?</div>
    <h2 class="hp-section-title">Tudo que você precisa em um só lugar</h2>
    <p class="hp-section-desc">Simples, rápido e seguro para compradores e organizadores de eventos.</p>

    <div class="hp-feature-grid">
        <div class="hp-feature-card">
            <div class="hp-feature-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <div class="hp-feature-title">Compra segura</div>
            <div class="hp-feature-desc">Seus dados e pagamentos protegidos com autenticação e criptografia de ponta a ponta.</div>
        </div>

        <div class="hp-feature-card">
            <div class="hp-feature-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <div class="hp-feature-title">Gestão de eventos</div>
            <div class="hp-feature-desc">Crie e gerencie eventos com controle total de capacidade, preços e disponibilidade.</div>
        </div>

        <div class="hp-feature-card">
            <div class="hp-feature-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                </svg>
            </div>
            <div class="hp-feature-title">Cupons de desconto</div>
            <div class="hp-feature-desc">Aplique cupons exclusivos e aproveite promoções especiais nos eventos disponíveis.</div>
        </div>

        <div class="hp-feature-card">
            <div class="hp-feature-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
            <div class="hp-feature-title">Perfil completo</div>
            <div class="hp-feature-desc">Acompanhe todos os seus ingressos, histórico de compras e gerencie suas reservas.</div>
        </div>

        <div class="hp-feature-card">
            <div class="hp-feature-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>
                </svg>
            </div>
            <div class="hp-feature-title">Vagas em tempo real</div>
            <div class="hp-feature-desc">Capacidade atualizada instantaneamente a cada compra, sem risco de superlotação.</div>
        </div>

        <div class="hp-feature-card">
            <div class="hp-feature-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <div class="hp-feature-title">Cancelamento fácil</div>
            <div class="hp-feature-desc">Precisa cancelar? Devolva seu ingresso com um clique e a vaga volta automaticamente.</div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="hp-cta">
    <h2>Pronto para o próximo evento?</h2>
    <p>Crie sua conta agora e garanta seus ingressos em segundos.</p>
    @if (!Session.EstaLogado)
    {
        <button class="hp-cta-btn" @onclick='() => Navigation.NavigateTo("/cadastro-user")'>
            Criar conta grátis
        </button>
    }
    else
    {
        <button class="hp-cta-btn" @onclick='() => Navigation.NavigateTo("/eventos")'>
            Ver eventos disponíveis
        </button>
    }
</section>

<!-- FOOTER -->
<footer class="hp-footer">
    © 2026 <span>TicketPrime</span> — Todos os direitos reservados.
</footer>

@code {
    private int totalEventos = 0;
    private int totalReservas = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var eventos = await Http.GetFromJsonAsync<List<object>>("api/eventos");
            totalEventos = eventos?.Count ?? 0;
        }
        catch { }

        try
        {
            if (Session.EstaLogado)
            {
                var reservas = await Http.GetFromJsonAsync<List<object>>("api/reservas/minhas");
                totalReservas = reservas?.Count ?? 0;
            }
        }
        catch { }
    }
}
