@page "/eventos"
@using src.Models
@using TicketPrime.Web.Services
@inject HttpClient Http
@inject SessionService Session
@rendermode InteractiveServer

<PageTitle>Eventos - TicketPrime</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Lista de Eventos</h3>
        @if (Session.EhAdmin)
        {
            <a href="/eventos/novo" class="btn btn-success">Novo Evento</a>
        }
    </div>

    @if (eventos == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Carregando eventos...</p>
        </div>
    }
    else if (!eventos.Any())
    {
        <div class="alert alert-warning">Nenhum evento cadastrado no momento.</div>
    }
    else
    {
        <table class="table table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Nome</th>
                    <th>Data</th>
                    <th>Capacidade</th>
                    <th>Preço</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evento in eventos)
                {
                    <tr>
                        <td>@evento.Nome</td>
                        <td>@evento.DataEvento.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@evento.CapacidadeTotal</td>
                        <td>@evento.PrecoPadrao.ToString("C")</td>
                        <td>
                            <button class="btn btn-sm btn-primary">Comprar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Evento>? eventos;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            eventos = await Http.GetFromJsonAsync<List<Evento>>("api/eventos");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Erro ao carregar eventos: {ex.Message}");
        }
    }
}