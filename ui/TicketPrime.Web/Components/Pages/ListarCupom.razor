@page "/cupons"
@using src.Models
@using TicketPrime.Web.Services
@rendermode InteractiveServer
@using src.Service
@inject CupomService CupomService
@inject SessionService Session
@inject IJSRuntime JS

<PageTitle>Gerenciar Cupons</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Cupons Cadastrados</h2>
        @if (Session.EhAdmin)
        {
            <a href="/cupons/cadastrar" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Novo Cupom
            </a>
        }
    </div>

    @if (cupons == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Carregando cupons...</p>
        </div>
    }
    else if (!cupons.Any())
    {
        <div class="alert alert-info">Nenhum cupom encontrado.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Código</th>
                        <th>Desconto</th>
                        <th>Valor Mínimo</th>
                        @if (Session.EhAdmin)
                        {
                            <th class="text-center">Ações</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cupom in cupons)
                    {
                        <tr>
                            <td class="align-middle fw-bold">@cupom.Codigo</td>
                            <td class="align-middle">@cupom.PorcentagemDesconto%</td>
                            <td class="align-middle">R$ @cupom.valorMinimoregra</td>
                            @if (Session.EhAdmin)
                            {
                                <td class="text-center">
                                    <button class="btn btn-danger btn-sm"
                                            @onclick="() => ConfirmarExclusao(cupom.Codigo)">
                                        <i class="bi bi-trash"></i> Excluir
                                    </button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Cupom>? cupons;

    protected override async Task OnInitializedAsync()
    {
        await CarregarCupons();
    }

    private async Task CarregarCupons()
    {
        try
        {
            var lista = await CupomService.ListarAsync();
            cupons = lista.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar: {ex.Message}");
        }
    }

    private async Task ConfirmarExclusao(string codigo)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Tem certeza que deseja excluir o cupom {codigo}?");
        if (confirmado)
            await Deletar(codigo);
    }

    private async Task Deletar(string codigo)
    {
        try
        {
            var removido = await CupomService.DeletarAsync(codigo);
            if (removido)
            {
                cupons?.RemoveAll(c => c.Codigo == codigo);
                StateHasChanged();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Cupom não encontrado no banco de dados.");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Erro ao deletar: {ex.Message}");
        }
    }
}