﻿@using TicketPrime.Web.Services
@inject SessionService Session
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">🎟️ TicketPrime</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (!Session.EstaLogado)
        {
            <!-- Usuário NÃO logado: mostra login e cadastro -->
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login">
                    <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Login
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="cadastro-user">
                    <span class="bi bi-person-plus-fill" aria-hidden="true"></span> Cadastro
                </NavLink>
            </div>
        }

        @if (Session.EstaLogado)
        {
            <!-- Usuário logado: mostra eventos disponíveis -->
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/eventos">
                    <span class="bi bi-calendar-event" aria-hidden="true"></span> Eventos
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/cupons">
                    <span class="bi bi-tag-fill" aria-hidden="true"></span> Cupons
                </NavLink>
            </div>
        }

        @if (Session.EhAdmin)
        {
            <!-- Somente ADMIN vê essas opções -->
            <hr class="text-white my-1" />
            <div class="nav-item px-3">
                <small class="text-white-50 ps-3">Admin</small>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/eventos/novo">
                    <span class="bi bi-plus-circle-fill" aria-hidden="true"></span> Criar Evento
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/cupons/cadastrar">
                    <span class="bi bi-plus-circle-fill" aria-hidden="true"></span> Criar Cupom
                </NavLink>
            </div>
        }

        @if (Session.EstaLogado)
        {
            <!-- Botão de logout -->
            <hr class="text-white my-1" />
            <div class="nav-item px-3">
                <small class="text-white-50 ps-3">Olá, @Session.Nome</small>
            </div>
            <div class="nav-item px-3">
                <button class="nav-link btn btn-link text-white" @onclick="Logout">
                    <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Sair
                </button>
            </div>
        }

    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Session.OnChange += async () => await InvokeAsync(StateHasChanged);
    }

    private void Logout()
    {
        Session.Deslogar();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        Session.OnChange -= async () => await InvokeAsync(StateHasChanged);
    }
}

