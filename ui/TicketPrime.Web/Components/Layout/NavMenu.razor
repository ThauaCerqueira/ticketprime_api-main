﻿﻿@using TicketPrime.Web.Services
@inject SessionService Session
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer

<style>
    .navbar-top {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 64px;
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(91,91,214,0.08);
    }

    .navbar-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        cursor: pointer;
    }

    .navbar-logo-icon {
        width: 36px; height: 36px;
        background: #5B5BD6;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .navbar-logo-icon svg { width: 18px; height: 18px; fill: white; }

    .navbar-logo-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    .navbar-right {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        position: relative;
    }

    .navbar-user-info {
        font-size: 0.875rem;
        color: #6B7280;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .navbar-user-badge {
        background: #F0F0FF;
        color: #5B5BD6;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .navbar-dots-btn {
        width: 40px; height: 40px;
        background: transparent;
        border: 1.5px solid #E5E7EB;
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-direction: column;
        gap: 4px;
        padding: 0;
    }

    .navbar-dots-btn:hover {
        background: #F0F0FF;
        border-color: #5B5BD6;
    }

    .navbar-dots-btn span {
        width: 4px; height: 4px;
        background: #374151;
        border-radius: 50%;
        display: block;
        transition: background 0.2s;
    }

    .navbar-dots-btn:hover span { background: #5B5BD6; }

    .navbar-dropdown {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
        border: 1.5px solid #F1F5F9;
        min-width: 220px;
        overflow: hidden;
        animation: dropIn 0.15s ease;
        z-index: 300;
    }

    @@keyframes dropIn {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .navbar-dropdown-header {
        padding: 1rem 1.2rem 0.8rem;
        border-bottom: 1px solid #F1F5F9;
    }

    .navbar-dropdown-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    .navbar-dropdown-role {
        font-size: 0.75rem;
        color: #6B7280;
        margin-top: 0.1rem;
    }

    .navbar-dropdown-item {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.8rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: #374151;
        cursor: pointer;
        background: transparent;
        border: none;
        width: 100%;
        text-align: left;
        text-decoration: none;
        transition: background 0.15s;
    }

    .navbar-dropdown-item:hover { background: #F8FAFC; color: #5B5BD6; }

    .navbar-dropdown-item svg {
        width: 17px; height: 17px;
        flex-shrink: 0;
        stroke: currentColor;
    }

    .navbar-dropdown-divider {
        height: 1px;
        background: #F1F5F9;
        margin: 0.3rem 0;
    }

    .navbar-dropdown-item-danger {
        color: #DC2626 !important;
    }

    .navbar-dropdown-item-danger:hover { background: #FEF2F2 !important; color: #DC2626 !important; }

    .navbar-dropdown-section {
        padding: 0.3rem 0;
    }

    .navbar-dropdown-section-label {
        padding: 0.4rem 1.2rem 0.2rem;
        font-size: 0.7rem;
        font-weight: 600;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .navbar-login-btn {
        padding: 0.5rem 1.2rem;
        background: #5B5BD6;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        text-decoration: none;
    }

    .navbar-login-btn:hover { background: #4949c4; color: white; }

    .navbar-overlay {
        position: fixed;
        inset: 0;
        z-index: 199;
    }
</style>

<nav class="navbar-top">
    <div class="navbar-logo" @onclick='() => Navigation.NavigateTo("/")'>
        <div class="navbar-logo-icon">
            <svg viewBox="0 0 24 24"><path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4zM12 17.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0-7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>
        </div>
        <span class="navbar-logo-name">TicketPrime</span>
    </div>

    <div class="navbar-right">
        @if (!Session.EstaLogado)
        {
            <a href="/login" class="navbar-login-btn">Entrar</a>
        }
        else
        {
            <div class="navbar-user-info">
                <span>@Session.Nome</span>
                <span class="navbar-user-badge">@Session.Perfil</span>
            </div>

            <button class="navbar-dots-btn" @onclick="ToggleMenu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        }

        @if (menuAberto)
        {
            <div class="navbar-overlay" @onclick="FecharMenu"></div>
            <div class="navbar-dropdown">

                @if (Session.EstaLogado)
                {
                    <div class="navbar-dropdown-header">
                        <div class="navbar-dropdown-name">@Session.Nome</div>
                        <div class="navbar-dropdown-role">@Session.Perfil</div>
                    </div>
                }

                <div class="navbar-dropdown-section">
                    <button class="navbar-dropdown-item" @onclick='() => Navegar("/eventos")'>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        Eventos
                    </button>
                    <button class="navbar-dropdown-item" @onclick='() => Navegar("/cupons")'>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                            <path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/>
                        </svg>
                        Cupons
                    </button>

                    @if (Session.EstaLogado)
                    {
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/perfil")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                            Meu Perfil
                        </button>
                    }

                    @if (Session.EhAdmin)
                    {
                        <div class="navbar-dropdown-divider"></div>
                        <div class="navbar-dropdown-section-label">Admin</div>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/eventos/novo")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                            Criar Evento
                        </button>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/cupons/cadastrar")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                            Criar Cupom
                        </button>
                    }
                </div>

                @if (Session.EstaLogado)
                {
                    <div class="navbar-dropdown-divider"></div>
                    <div class="navbar-dropdown-section">
                        <button class="navbar-dropdown-item navbar-dropdown-item-danger" @onclick="Logout">
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                            </svg>
                            Sair
                        </button>
                    </div>
                }
                else
                {
                    <div class="navbar-dropdown-divider"></div>
                    <div class="navbar-dropdown-section">
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/login")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
                            </svg>
                            Entrar
                        </button>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/cadastro-user")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
                            </svg>
                            Criar conta
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</nav>

@code {
    private bool menuAberto = false;

    protected override void OnInitialized()
    {
        Session.OnChange += async () => await InvokeAsync(StateHasChanged);
    }

    private void ToggleMenu() => menuAberto = !menuAberto;
    private void FecharMenu() => menuAberto = false;

    private void Navegar(string url)
    {
        menuAberto = false;
        Navigation.NavigateTo(url);
    }

    private void Logout()
    {
        menuAberto = false;
        Session.Deslogar();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    void IDisposable.Dispose()
    {
        Session.OnChange -= async () => await InvokeAsync(StateHasChanged);
    }
}
